generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(uuid())
  phone          String   @unique
  name           String
  shopName       String
  city           String
  aadharFront    String?
  aadharBack     String?
  overrideSlabId String?
  createdAt      DateTime @default(now())
  registeredAt   DateTime @default(now())
}

model Submission {
  id              String   @id @default(uuid())
  userId          String?
  phone           String
  name            String?
  shopName        String?
  city            String?
  capacity        String
  invoiceNo       String?
  invoiceNo_input String?
  invoiceDate     String?
  aadharFront     String?
  aadharBack      String?
  status          String   @default("pending")
  claimedGift     String?
  timestamp       DateTime @default(now())
}

model Settings {
  id                 String   @id @default("global")
  rewardsDistributed Boolean  @default(false)
  updatedAt          DateTime @updatedAt
}

model Slab {
  id        String   @id @default(uuid())
  level     String
  target    Int
  giftA     String
  giftAImg  String?
  giftB     String?
  giftBImg  String?
  giftC     String?
  giftCImg  String?
  giftD     String?
  giftDImg  String?
  updatedAt DateTime @updatedAt
}

