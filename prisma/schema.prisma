generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(uuid())
  phone          String   @unique
  email          String?  @unique
  name           String
  shopName       String
  city           String
  passwordHash   String?
  authMethod     String   @default("phone_otp")
  emailVerified  Boolean  @default(false)
  aadharFront    String?
  aadharBack     String?
  overrideSlabId String?
  createdAt      DateTime @default(now())
  registeredAt   DateTime @default(now())

  redeemedCoupons Coupon[]
  couponRedemptions CouponRedemption[]
}

model VerificationCode {
  id         String   @id @default(uuid())
  email      String
  purpose    String
  codeHash   String
  expiresAt  DateTime
  verifiedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([email, purpose, createdAt])
}

model Submission {
  id              String   @id @default(uuid())
  userId          String?
  phone           String
  name            String?
  shopName        String?
  city            String?
  capacity        String
  invoiceNo       String?
  invoiceNo_input String?
  invoiceDate     String?
  aadharFront     String?
  aadharBack      String?
  status          String   @default("pending")
  claimedGift     String?
  timestamp       DateTime @default(now())
}

model Settings {
  id                 String   @id @default("global")
  rewardsDistributed Boolean  @default(false)
  updatedAt          DateTime @updatedAt
}

model Slab {
  id        String   @id @default(uuid())
  level     String
  target    Int
  giftA     String
  giftAImg  String?
  giftB     String?
  giftBImg  String?
  giftC     String?
  giftCImg  String?
  giftD     String?
  giftDImg  String?
  updatedAt DateTime @updatedAt

  couponRedemptions CouponRedemption[]
}

model SupportTicket {
  id        String   @id @default(uuid())
  phone     String
  category  String
  message   String
  status    String   @default("pending")
  createdAt DateTime @default(now())
}

enum CouponStatus {
  AVAILABLE
  RESERVED
  REDEEMED
  EXPIRED
  DISABLED
}

model Coupon {
  id             String         @id @default(cuid())
  code           String         @unique
  status         CouponStatus   @default(AVAILABLE)

  campaignId     String?
  batchId        String?
  note           String?

  expiresAt      DateTime?
  redeemedAt     DateTime?
  redeemedById   String?
  redeemedBy     User?          @relation(fields: [redeemedById], references: [id])

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  redemption     CouponRedemption?
  
  createdById    String?
  updatedById    String?

  @@index([code])
  @@index([status])
  @@index([redeemedById])
  @@index([campaignId])
  @@index([batchId])
}

model CouponRedemption {
  id             String   @id @default(cuid())

  couponId       String   @unique
  coupon         Coupon   @relation(fields: [couponId], references: [id])

  userId         String
  user           User     @relation(fields: [userId], references: [id])

  slabId         String?
  slab           Slab?    @relation(fields: [slabId], references: [id])

  selectedGift   String

  phone          String?
  name           String?

  redeemedAt     DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  ipAddress      String?
  userAgent      String?

  @@index([userId])
  @@index([couponId])
  @@index([slabId])
  @@index([phone])
}
